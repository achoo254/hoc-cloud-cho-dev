{
  "name": "hoc-cloud-labs",
  "version": "1.0.0",
  "private": true,
  "description": "Static server for cloud/devops learning labs",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "node --env-file=.env server/server.js",
    "dev": "node --env-file=.env.development --watch server/server.js",
    "dev:server": "node --env-file=.env.development --watch server/server.js",
    "dev:app": "pnpm -C app exec vite",
    "build:app": "pnpm -C app run build",
    "build:server": "esbuild server/server.js --bundle --platform=node --target=node22 --format=esm --outfile=dist-server/server.bundle.js --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "firebase-admin": "^13.8.0",
    "hono": "^4.6.14",
    "meilisearch": "^0.57.0",
    "mongoose": "^9.5.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "zod": "^4.3.6"
  }
}
