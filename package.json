{
  "name": "hoc-cloud-labs",
  "version": "1.0.0",
  "private": true,
  "description": "Static server for cloud/devops learning labs",
  "type": "module",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node --watch server/server.js",
    "dev:server": "node --watch server/server.js",
    "dev:app": "cd app && npx vite",
    "build:app": "cd app && npm run build",
    "sync-labs": "node server/scripts/sync-labs-to-db.js",
    "validate:schema": "node scripts/validate-lab-schema.js",
    "export:labs": "node scripts/fixtures-to-ts.mjs",
    "gen:content": "node scripts/fixtures-to-ts.mjs && node scripts/generate-labs-index.mjs && node scripts/generate-search-index.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "zod": "^4.3.6"
  }
}
