# /etc/nginx/conf.d/hoc-cloud.conf
# Reverse proxy: hoc-cloud.inetdev.io.vn -> Vite SPA (app/dist/) + Hono API on :8387
#
# Setup steps:
#   1. Copy to /etc/nginx/conf.d/hoc-cloud.conf
#   2. Run: nginx -t
#   3. sudo systemctl reload nginx
#
# TLS is terminated by Cloudflare (orange-cloud proxied). Origin stays on :80.
# Refresh Cloudflare IP list periodically: https://www.cloudflare.com/ips/
# `set_real_ip_from` blocks below cần được update khi CF xuất ranges mới.

# --- Cloudflare origin: rewrite $remote_addr thành client IP thật ---
# Phải đặt ở http context (file này được include vào http {}).
set_real_ip_from 103.21.244.0/22;
set_real_ip_from 103.22.200.0/22;
set_real_ip_from 103.31.4.0/22;
set_real_ip_from 104.16.0.0/13;
set_real_ip_from 104.24.0.0/14;
set_real_ip_from 108.162.192.0/18;
set_real_ip_from 131.0.72.0/22;
set_real_ip_from 141.101.64.0/18;
set_real_ip_from 162.158.0.0/15;
set_real_ip_from 172.64.0.0/13;
set_real_ip_from 173.245.48.0/20;
set_real_ip_from 188.114.96.0/20;
set_real_ip_from 190.93.240.0/20;
set_real_ip_from 197.234.240.0/22;
set_real_ip_from 198.41.128.0/17;
set_real_ip_from 2400:cb00::/32;
set_real_ip_from 2606:4700::/32;
set_real_ip_from 2803:f800::/32;
set_real_ip_from 2405:b500::/32;
set_real_ip_from 2405:8100::/32;
set_real_ip_from 2a06:98c0::/29;
set_real_ip_from 2c0f:f248::/32;
real_ip_header     CF-Connecting-IP;
real_ip_recursive  on;

server {
    listen 80;
    listen [::]:80;
    server_name hoc-cloud.inetdev.io.vn;

    access_log /var/log/nginx/hoc-cloud.access.log;
    error_log  /var/log/nginx/hoc-cloud.error.log;

    # Serve Vite SPA from dist/
    root /var/www/hoccloud/app/dist;
    index index.html;

    # gzip for text assets
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml font/woff2;
    gzip_min_length 1024;

    # --- Auth routes (OAuth flow) ---
    location /auth/ {
        proxy_pass         http://127.0.0.1:8387;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # --- API proxy (Hono on :8387) ---
    location /api/ {
        proxy_pass         http://127.0.0.1:8387;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # --- WebSocket: terminal (/ws/terminal/:labSlug) ---
    # Cloudflare free/pro đóng WS sau ~100s idle — client-side keepalive
    # trong web-terminal.tsx gửi zero-byte frame mỗi 60s để giữ connection.
    location /ws/ {
        proxy_pass         http://127.0.0.1:8387;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Byte-by-byte flush cho xterm; WS không dùng buffering/cache.
        proxy_buffering    off;
        proxy_cache        off;

        # tmux session kéo dài; cap ở idle-timeout server-side (30 phút).
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # --- SSE endpoint — buffering MUST be off for EventSource to work ---
    location /sse {
        proxy_pass         http://127.0.0.1:8387;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        '';
        # Disable all buffering so SSE frames are flushed immediately
        proxy_buffering    off;
        proxy_cache        off;
        proxy_read_timeout 3600s;
        chunked_transfer_encoding on;
    }

    # --- Health check ---
    location /healthz {
        proxy_pass         http://127.0.0.1:8387;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
    }

    # --- Hashed static assets: immutable cache (1 year) ---
    # Vite outputs content-hash filenames (e.g. index-CbMnl0VR.css) so these
    # can be cached indefinitely — a new deploy produces new filenames.
    location ~* \.(js|css|woff2|svg|png|jpg|webp|ico)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    # --- HTML: no-cache so users always get latest entrypoint ---
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma        "no-cache";
        add_header Expires       "0";
    }

    # --- SPA fallback: all non-file routes served index.html ---
    location / {
        try_files $uri $uri/ /index.html;
    }

    # --- Legacy archive: read-only static browse (30-day retention) ---
    # Remove this block after legacy cleanup (2 weeks post-cutover).
    location /legacy/ {
        alias      /var/www/hoccloud/legacy/;
        autoindex  on;
        add_header Cache-Control "no-store";
    }
}

# NOTE: Cloudflare proxied (orange-cloud) → TLS kết thúc tại edge.
# Nếu sau này đổi sang direct/grey-cloud, chạy:
#   certbot --nginx -d hoc-cloud.inetdev.io.vn
# để certbot tự thêm block :443 + redirect HTTP→HTTPS.
