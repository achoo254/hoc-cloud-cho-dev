# /etc/nginx/conf.d/hoc-cloud.conf
# Reverse proxy: hoc-cloud.inetdev.io.vn -> Node.js on 127.0.0.1:8387
# After testing, run: certbot --nginx -d hoc-cloud.inetdev.io.vn
# Certbot will auto-inject the SSL server block + HTTP->HTTPS redirect.

server {
    listen 80;
    listen [::]:80;
    server_name hoc-cloud.inetdev.io.vn;

    access_log /var/log/nginx/hoc-cloud.access.log;
    error_log  /var/log/nginx/hoc-cloud.error.log;

    # gzip for text assets (Hono serves raw)
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    location / {
        proxy_pass http://127.0.0.1:8387;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}
