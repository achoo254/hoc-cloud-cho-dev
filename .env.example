# Copy to .env and fill in.
NODE_ENV=development
PORT=8387

# MongoDB connection string
MONGODB_URI=mongodb://<MONGO_USER>:<MONGO_PASSWORD>@<HOST>:27017/<DB_NAME>

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=<your_master_key_here>

# Absolute base URL — used for canonical meta tags.
# Dev: Vite dev server port (5175). Prod: public domain.
PUBLIC_BASE_URL=http://localhost:5175

# Firebase Admin (BE) — verify ID tokens
# Download service account JSON from Firebase Console → Project Settings → Service accounts
# Value can be raw JSON or base64-encoded for easier env injection
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
