# Copy to .env and fill in.
NODE_ENV=development
PORT=8387

# SQLite path (relative to project root)
SQLITE_DB_PATH=./data/hoccloud.db

# Absolute base URL — used for canonical meta tags and OAuth redirect.
# Dev: Use Vite dev server port (5175) so OAuth callback returns to FE.
# Prod: Use your public domain (e.g., https://hoccloud.com).
PUBLIC_BASE_URL=http://localhost:5175

# GitHub OAuth (create app at: github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
