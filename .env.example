# Copy to .env and fill in.
NODE_ENV=development
PORT=8387

# GitHub OAuth App (Settings → Developer settings → OAuth Apps)
#   Homepage URL:       http://localhost:8387         (dev) / https://hoc-cloud.inetdev.io.vn (prod)
#   Callback URL:       http://localhost:8387/auth/github/callback    (add both dev + prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ADMIN_WHITELIST=achoo254

# Session / CSRF signing (random 32+ bytes, e.g. `openssl rand -hex 32`)
SESSION_SECRET=dev-secret-change-me-please

# SQLite path (relative to project root)
SQLITE_DB_PATH=./data/hoccloud.db

# Absolute base URL — used for OAuth redirect + canonical meta tags.
PUBLIC_BASE_URL=http://localhost:8387
