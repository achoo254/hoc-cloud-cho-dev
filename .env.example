# Copy to .env and fill in. (.env đã gitignore — KHÔNG commit giá trị thật)

# --- Core ---
NODE_ENV=development
PORT=8387
# Bind address (optional, default 127.0.0.1)
HOST=127.0.0.1
# Hiển thị ở /healthz (optional, default "dev"). CI/deploy thường set = git sha.
APP_VERSION=dev

# --- MongoDB (required) ---
MONGODB_URI=mongodb://<MONGO_USER>:<MONGO_PASSWORD>@<HOST>:27017/<DB_NAME>

# --- Meilisearch (required) ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=<your_master_key_here>

# --- Misc ---
# Absolute base URL — dùng cho canonical meta tags.
# Dev: Vite dev server port (5175). Prod: public domain.
PUBLIC_BASE_URL=http://localhost:5175
# Ép Secure flag cho session cookie (optional; "1" = bật).
# Mặc định auto-bật khi request đến qua x-forwarded-proto=https.
COOKIE_SECURE=

# --- Firebase Admin (BE) — verify ID token ---
# Download service account JSON: Firebase Console → Project Settings → Service accounts.
# Value chấp nhận raw JSON hoặc base64-encoded (dễ inject qua env).
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
